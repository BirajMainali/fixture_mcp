{
  "name": "fixture-mcp",
  "version": "1.0.5",
  "description": "MCP server for stateful API testing by AI agents. Persists sessions, context, events, and workflows in SQLite via Drizzle ORM.",
  "main": "build/index.js",
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "api-testing",
    "testing",
    "ai-agents",
    "sqlite",
    "drizzle"
  ],
  "author": "birajmainali",
  "license": "MIT",
  "type": "module",
  "bin": {
    "fixture-mcp": "./build/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BirajMainali/fixture_mcp.git"
  },
  "bugs": {
    "url": "https://github.com/BirajMainali/fixture_mcp/issues"
  },
  "homepage": "https://github.com/BirajMainali/fixture_mcp#readme",
  "engines": {
    "node": ">=19"
  },
  "scripts": {
    "build": "vitest run && tsc && chmod 755 build/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "postinstall": "npm rebuild better-sqlite3"
  },
  "files": [
    "build",
    "drizzle"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
